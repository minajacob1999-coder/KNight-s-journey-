[sub_resource type="GDScript" id="GDScript_q6r6c"]
script/source = "extends CharacterBody2D

const SPEED = 300.0
const JUMP_VELOCITY = -400.0

# إعدادات الصحة
var health: int = 100
var max_health: int = 100
const DAMAGE_AMOUNT = 10

var spawn_point: Vector2
var is_dead: bool = false
var is_attacking: bool = false

@onready var animated_sprite: AnimatedSprite2D = $AnimatedSprite2D
@export var health_bar: TextureProgressBar
@export var joystick: Control

var joystick_direction: float = 0.0

func _ready():
	spawn_point = global_position

	if health_bar:
		health_bar.update_health(health, max_health)
	else:
		push_error(\"HealthBar not assigned!\")

	if joystick and joystick.has_signal(\"moved\"):
		joystick.connect(\"moved\", Callable(self, \"_on_joystick_moved\"))
	else:
		push_error(\"Joystick not assigned or missing signal!\")

	animated_sprite.animation_finished.connect(_on_animation_finished)

func _on_joystick_moved(horizontal: float):
	joystick_direction = horizontal

func _physics_process(delta: float) -> void:
	if is_dead or is_attacking:
		return

	if not is_on_floor():
		velocity += get_gravity() * delta

	# القفز
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = JUMP_VELOCITY
		animated_sprite.play(\"jump\")

	# الحركة
	var direction_input = Input.get_axis(\"ui_left\", \"ui_right\")
	var total_direction = direction_input + joystick_direction
	total_direction = clamp(total_direction, -1.0, 1.0)

	if total_direction != 0:
		velocity.x = total_direction * SPEED
		animated_sprite.flip_h = total_direction < 0
		if is_on_floor():
			animated_sprite.play(\"run\")
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)
		if is_on_floor():
			animated_sprite.play(\"idle\")

	if not is_on_floor() and velocity.y > 0:
		animated_sprite.play(\"fall\")

	move_and_slide()

# الهجوم
func attack():
	if is_dead or is_attacking:
		return

	is_attacking = true
	animated_sprite.play(\"attack\")

# استقبال الإدخال
func _input(event: InputEvent):
	if event.is_action_pressed(\"attack\"):
		attack()

# نهاية الأنيميشن
func _on_animation_finished():
	if animated_sprite.animation == \"attack\":
		is_attacking = false

		if is_on_floor():
			if abs(velocity.x) > 0:
				animated_sprite.play(\"run\")
			else:
				animated_sprite.play(\"idle\")
		else:
			animated_sprite.play(\"fall\")

# الضرر
func apply_damage():
	if is_dead:
		return

	health = max(0, health - DAMAGE_AMOUNT)

	if health_bar and health_bar.has_method(\"update_health\"):
		health_bar.update_health(health, max_health)

	if health <= 0:
		die()

func die():
	is_dead = true

	if health_bar and health_bar.has_method(\"update_health\"):
		health_bar.update_health(0, max_health)

	await get_tree().create_timer(0.5).timeout

	health = max_health
	global_position = spawn_point
	velocity = Vector2.ZERO

	if health_bar and health_bar.has_method(\"update_health\"):
		health_bar.update_health(health, max_health)

	is_dead = false
"

