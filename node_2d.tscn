[sub_resource type="GDScript" id="GDScript_j7wrs"]
resource_name = "helthbar"
script/source = "extends TextureProgressBar

# مدة ظهور الشريط قبل الاختفاء (بالثواني)
@export var display_duration: float = 2.0

# هل نستخدم تأثير التلاشي بدل الإخفاء المفاجئ؟
@export var use_fade_out: bool = true

# مدة تأثير التلاشي (بالثواني)
@export var fade_out_duration: float = 0.3

var hide_timer: Timer

func _ready():
	# نبدأ مخفيين
	visible = false
	
	# إنشاء المؤقت لإخفاء الشريط بعد فترة
	hide_timer = Timer.new()
	add_child(hide_timer)
	hide_timer.one_shot = true
	hide_timer.timeout.connect(_on_hide_timer_timeout)

# دالة عامة لتحديث قيمة الشريط وإظهاره
func update_health(current_health: int, max_health: int):
	# تعيين القيم
	max_value = max_health
	value = current_health
	
	# إذا كان الشريط مخفيًا، نظهره
	if not visible:
		visible = true
		# نضمن أن الشفافية كاملة عند الظهور (لحالة استخدام التلاشي)
		modulate.a = 1.0
	
	# نعيد ضبط المؤقت (لو كان يعمل سابقًا نوقفه ونبدا من جديد)
	hide_timer.stop()
	hide_timer.start(display_duration)

# استدعاء عند انتهاء المؤقت
func _on_hide_timer_timeout():
	if use_fade_out:
		# تأثير تلاشي سلس
		var tween = create_tween()
		tween.tween_property(self, \"modulate:a\", 0.0, fade_out_duration)
		await tween.finished
		visible = false
		modulate.a = 1.0  # نعيد الشفافية للظهور القادم
	else:
		# إخفاء مباشر
		visible = false
"

